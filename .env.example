# Job Agent Coordinator - Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# API Tokens
# =============================================================================

# Apify API token (for Glassdoor/Indeed MCP integration)
APIFY_API_TOKEN=your_apify_token_here

# Google Cloud Project (optional - auto-detected if using gcloud auth)
# GOOGLE_CLOUD_PROJECT=your-project-id

# =============================================================================
# Logging Configuration
# =============================================================================

# Overall log level: DEBUG, INFO, WARNING, ERROR
# DEBUG shows detailed internal operations
# INFO shows agent lifecycle and key events (default)
JOB_AGENT_LOG_LEVEL=INFO

# Enable verbose model response logging (shows actual LLM outputs)
# Set to "true" to see full model responses in logs
VERBOSE_MODEL_LOGGING=false

# Maximum characters to display for model responses
# Set to 0 for unlimited, or a number like 500, 1000, 1500
MODEL_RESPONSE_MAX_CHARS=500

# =============================================================================
# Storage Configuration
# =============================================================================

# ChromaDB persistence directory (optional)
# Default: ~/.job_agent_coordinator/history
# CHROMADB_PERSIST_DIR=/path/to/custom/directory

# PDF output directory (optional)
# Default: ~/.job_agent_coordinator/generated_pdfs
# PDF_OUTPUT_DIR=/path/to/custom/pdf/directory

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable MCP integrations
# MCP_ENABLED=true

# Use Vertex AI (true) or Gemini API directly (false)
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_LOCATION=global

# =============================================================================
# Pre-seeded Prompts (for quick testing)
# =============================================================================

# Pre-seed the agent with an initial prompt (useful for testing)
# This will be displayed as a suggested first query in the UI
# INITIAL_PROMPT="search seattle for software engineering manager jobs"
